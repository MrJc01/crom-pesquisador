# ==========================================
# CROM ENGINE - ARQUIVO DE CONFIGURAÇÃO BASE
# ==========================================
# Renomeie este arquivo para .env no seu servidor (VPS) ou máquina local.

# --- ⚙️ BACKEND (GO API) ---
# Define a porta em que a API Go escutará.
# Padrão: 8080. Alterado para 8098 no VPS para evitar conflito com outros apps.
PORT=8098

# (Opcional) Chave mestre para tarefas de administração via API
# CROM_API_SECRET="sua-chave-ultra-secreta-aqui"


# --- 🖥️ FRONTEND (REACT/VITE) ---
# Em desenvolvimento (localhost), o React fará requests para esta URL.
# Em produção (VPS via NGINX), o React ignorará isso e usará a rota relativa `/api/`.
VITE_API_URL="http://localhost:8098/api"


# --- 🤖 CRAWLERS ---
# Máximo de concorrência global (Quantos sites simultâneos por json)
CRAWLER_MAX_CONCURRENCY=50

# Identificação oficial do bot nos logs globais (Robotstxt/HTTP)
CRAWLER_USER_AGENT="CROM-Bot/1.0 (+https://p.crom.run)"


# --- 🛡️ BANCO DE DADOS ---
# Caminhos padrões. Mude se quiser hospedar o DB em disco SSD dedicado.
DB_SITES_DIR="./data/sites"
DB_INDEX_DIR="./data/index"
