# ==========================================
# CROM Search Engine - .gitignore
# ==========================================

# 1. Dependências e Módulos
node_modules/
vendor/
.pnp
.pnp.js

# 2. Compilações e Builds
frontend/dist/
frontend/build/
backend/main
crawler/main
*.exe
*.exe~
*.dll
*.so
*.dylib

# 3. Bancos de Dados e Dados Locais
# Nós ignoramos os arquivos DB para que dados de teste locais não subam para o repositório,
# mas mantemos a pasta estrutural usando .gitkeep
data/sites/*.db
data/sites/*.db-shm
data/sites/*.db-wal
data/index/*.db
data/index/*.db-shm
data/index/*.db-wal

# 4. Logs e Arquivos Temporários
monitor/logs/*.log
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. Variáveis de Ambiente e Segredos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 6. IDEs, Editores e Arquivos do SO
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
.gemini/

# 7. Arquivos de Cache (Vite/React/Go)
.eslintcache
frontend/dist-ssr
frontend/.vite/
*.test.js.snap

# 8. Relatórios Gerados pelo Monitor
monitor/reports/*.md
